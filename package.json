{
  "name": "prototype-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that renders a Figma prototype in an iframe",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "prototype-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/ui dist/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2"
  }
}
